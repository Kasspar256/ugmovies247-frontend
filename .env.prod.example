NEXT_PUBLIC_APP_ENV="production"
NEXT_PUBLIC_SHOW_ENV_BADGE="false"
PORT="3000"

NEXT_PUBLIC_FIREBASE_API_KEY="your-prod-firebase-api-key"
NEXT_PUBLIC_FIREBASE_AUTH_DOMAIN="your-prod-project.firebaseapp.com"
NEXT_PUBLIC_FIREBASE_PROJECT_ID="your-prod-project"
NEXT_PUBLIC_FIREBASE_STORAGE_BUCKET="your-prod-project.firebasestorage.app"
NEXT_PUBLIC_FIREBASE_MESSAGING_SENDER_ID="your-prod-messaging-sender-id"
NEXT_PUBLIC_FIREBASE_APP_ID="your-prod-app-id"

FIREBASE_PROJECT_ID="your-prod-project"
FIREBASE_CLIENT_EMAIL="firebase-adminsdk-xxxxx@your-prod-project.iam.gserviceaccount.com"
FIREBASE_PRIVATE_KEY="-----BEGIN PRIVATE KEY-----\nYOUR_PROD_PRIVATE_KEY\n-----END PRIVATE KEY-----\n"

ADMIN_EMAILS="you@example.com"

TMDB_API_KEY="your-tmdb-key"

MAIL_HOST="mail.cyberpersons.com"
MAIL_PORT="587"
MAIL_SECURITY="STARTTLS"
MAIL_USER="your-smtp-user"
MAIL_PASS="your-smtp-password"
MAIL_FROM="contact@ugmovies247.com"
MAIL_FROM_NAME="UG Movies 247"
MAIL_REPLY_TO="info@ugmovies247.com"
SUPPORT_EMAIL="info@ugmovies247.com"

PAWAPAY_ENV="production"
PAWAPAY_BASE_URL="https://api.pawapay.io"
PAWAPAY_API_TOKEN="your-prod-pawapay-token"
APP_BASE_URL="https://ugmovies247.com"
PAWAPAY_ALLOWED_PROVIDERS="MTN_MOMO_UGA,AIRTEL_OAPI_UGA"
# PayFast card checkout defaults can still be overridden per plan with PAYFAST_<PLAN>_AMOUNT_ZAR
PAYFAST_PLAN_PRICES_ZAR="{\"daily\":10,\"seven_days\":25,\"fourteen_days\":32,\"monthly\":70,\"two_months\":100,\"three_months\":140,\"six_months\":270,\"twelve_months\":540}"
# Optional explicit override if callbacks land on a dedicated subdomain
# PAWAPAY_WEBHOOK_URL="https://ugmovies247.com/api/webhooks/pawapay"
# Enable after signed callbacks are configured and verified
# PAWAPAY_REQUIRE_SIGNED_CALLBACKS="true"

R2_ACCESS_KEY_ID="your-r2-access-key"
R2_SECRET_ACCESS_KEY="your-r2-secret"
R2_ENDPOINT_URL="https://your-account-id.r2.cloudflarestorage.com"
R2_BUCKET_NAME="your-prod-bucket"
R2_PUBLIC_BASE_URL="https://media.ugmovies247.com"

FFMPEG_PATH="/usr/bin/ffmpeg"
FFPROBE_PATH="/usr/bin/ffprobe"
VIDEO_MIN_FREE_DISK_BYTES="6442450944"
DIRECT_VIDEO_JOB_TIMEOUT_MS="14400000"
AUTH_COOKIE_DOMAIN=".ugmovies247.com"
