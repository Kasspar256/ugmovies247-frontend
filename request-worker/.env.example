# Firebase Admin credentials
FIREBASE_PROJECT_ID=ugmovies247k
FIREBASE_CLIENT_EMAIL=firebase-adminsdk-example@ugmovies247k.iam.gserviceaccount.com
FIREBASE_PRIVATE_KEY="-----BEGIN PRIVATE KEY-----\nCHANGE_ME\n-----END PRIVATE KEY-----\n"

# Firestore collections
MOVIE_REQUESTS_COLLECTION=movie_requests
REQUEST_PROCESSING_JOBS_COLLECTION=request_processing_jobs
MOVIES_COLLECTION=movies__production

# Dedicated request Telegram MTProto client session
# Create a separate Telegram account/session and a separate intake group for requests only.
# Do not reuse the main production Telegram worker session or group.
REQUEST_TELEGRAM_API_ID=123456
REQUEST_TELEGRAM_API_HASH=CHANGE_ME
REQUEST_TELEGRAM_SESSION_STRING=CHANGE_ME_STRING_SESSION
REQUEST_TELEGRAM_INTAKE_CHAT_IDS=-1001234567890
REQUEST_TELEGRAM_ALLOWED_SENDER_IDS=

# R2 / S3-compatible storage
R2_ENDPOINT=https://CHANGE_ME.r2.cloudflarestorage.com
R2_ACCESS_KEY_ID=CHANGE_ME
R2_SECRET_ACCESS_KEY=CHANGE_ME
R2_BUCKET=ugmovies-vault-prod
R2_PUBLIC_BASE_URL=https://media.ugmovies247.com
R2_KEY_PREFIX=requested

# Telegram worker output mode.
# r2 = upload the processed Telegram file directly to Cloudflare R2.
# local = copy the processed file to this VPS public files folder and reply with a temporary VPS link,
#         matching the current production Telegram worker concept. Requires a web server/domain.
REQUEST_TELEGRAM_OUTPUT_MODE=r2
REQUEST_PUBLIC_FILES_DIR=/var/lib/ugmovies-request-worker/public/files
REQUEST_PUBLIC_BASE_URL=https://request-worker.example.com:9443/files

# Worker runtime
WORK_DIR=/var/lib/ugmovies-request-worker/work
POLL_INTERVAL_MS=15000
FFMPEG_PRESET=veryfast
FFMPEG_CRF=21
PUBLIC_APP_BASE_URL=https://ugmovies247.com
APP_INTERNAL_BASE_URL=https://ugmovies247.com
REQUEST_WORKER_SECRET=CHANGE_ME_LONG_RANDOM_SECRET
WORKER_ID=request-vps-1
