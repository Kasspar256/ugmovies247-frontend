# Firebase Admin credentials
FIREBASE_PROJECT_ID=ugmovies247k
FIREBASE_CLIENT_EMAIL=firebase-adminsdk-example@ugmovies247k.iam.gserviceaccount.com
FIREBASE_PRIVATE_KEY="-----BEGIN PRIVATE KEY-----\nCHANGE_ME\n-----END PRIVATE KEY-----\n"

# Firestore collections
MOVIE_REQUESTS_COLLECTION=movie_requests
MOVIES_COLLECTION=movies__production

# R2 / S3-compatible storage
R2_ENDPOINT=https://CHANGE_ME.r2.cloudflarestorage.com
R2_ACCESS_KEY_ID=CHANGE_ME
R2_SECRET_ACCESS_KEY=CHANGE_ME
R2_BUCKET=ugmovies-vault-prod
R2_PUBLIC_BASE_URL=https://media.ugmovies247.com
R2_KEY_PREFIX=requested

# Worker runtime
WORK_DIR=/var/lib/ugmovies-request-worker/work
POLL_INTERVAL_MS=15000
FFMPEG_PRESET=veryfast
FFMPEG_CRF=21
PUBLIC_APP_BASE_URL=https://ugmovies247.com
